# Database
DATABASE_URL=postgresql://user:password@localhost:5432/defi_sentinel

# Redis
REDIS_URL=redis://localhost:6379

# RPC (Alchemy — get free key at https://alchemy.com)
ALCHEMY_RPC_ETH=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_WS_ETH=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_RPC_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# AI (Groq — get free key at https://console.groq.com)
GROQ_API_KEY=gsk_...

# Telegram Bot (optional — create via @BotFather)
TELEGRAM_BOT_TOKEN=

# Server
PORT=3001
NODE_ENV=development
